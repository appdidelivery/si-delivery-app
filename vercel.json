{
  "rewrites":[
    {
      "source": "/robots.txt",
      "destination": "/api/robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/(.*)",
      "has":[
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(whatsapp|facebookexternalhit|twitterbot|linkedinbot|telegrambot|discordbot).*"
        }
      ],
      "destination": "/api/social"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}